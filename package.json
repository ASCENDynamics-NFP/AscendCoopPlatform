{
  "name": "ascendcoopplatform",
  "version": "1.0.2",
  "author": "ASCENDynamics NFP",
  "homepage": "https://ASCENDynamics.org/",
  "scripts": {
    "generate-env:dev": "NODE_ENV=development node generate-env.js",
    "generate-env:prod": "NODE_ENV=production node generate-env.js",
    "set-bundle-id": "node configure-app.js",
    "build": "npm run build:dev",
    "build:dev": "npm run generate-env:dev && ng build --configuration development",
    "build:prod": "npm run generate-env:prod && ng build --configuration production",
    "start": "npm run generate-env:dev && ng serve --port 8100",
    "start:prod": "npm run generate-env:prod && ng serve --configuration production --port 8100",
    "format": "prettier --write .",
    "prepare": "husky",
    "ng": "ng",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --watch=false && npm --prefix functions test",
    "test:watch": "ng test --watch",
    "lint": "ng lint",
    "clean": "rm -rf node_modules package-lock.json",
    "postinstall": "patch-package"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.14",
    "@angular/cdk": "^21.2.12",
    "@angular/common": "^21.2.14",
    "@angular/compiler": "^21.2.14",
    "@angular/core": "^21.2.14",
    "@angular/fire": "^20.0.1",
    "@angular/forms": "^21.2.14",
    "@angular/google-maps": "^21.2.12",
    "@angular/platform-browser": "^21.2.14",
    "@angular/platform-browser-dynamic": "^21.2.14",
    "@angular/router": "^21.2.14",
    "@capacitor-community/apple-sign-in": "^7.1.0",
    "@capacitor/android": "^8.4.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/core": "^8.4.0",
    "@capacitor/haptics": "^8.0.1",
    "@capacitor/ios": "^8.4.0",
    "@capacitor/keyboard": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@googlemaps/markerclusterer": "^2.6.2",
    "@ionic/angular": "^8.8.8",
    "@ionic/cli": "^7.2.1",
    "@ionic/pwa-elements": "^3.1.1",
    "@ngrx/effects": "^21.1.0",
    "@ngrx/entity": "^21.1.0",
    "@ngrx/store": "^21.1.0",
    "@ngrx/store-devtools": "^21.1.0",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@southdevs/capacitor-google-auth": "^7.0.0",
    "chart.js": "^4.5.0",
    "dotenv": "^16.4.5",
    "firebase": "^12.13.0",
    "html2canvas": "^1.4.1",
    "ionicons": "^7.2.1",
    "jspdf": "^4.2.1",
    "ng2-charts": "^10.0.0",
    "ngrx-store-localstorage": "^20.1.0",
    "rxfire": "^6.0.5",
    "rxjs": "~7.8.0",
    "swiper": "^12.1.4",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^19.8.1",
    "@angular-eslint/eslint-plugin": "^19.8.1",
    "@angular-eslint/eslint-plugin-template": "^19.8.1",
    "@angular-eslint/schematics": "^19.8.1",
    "@angular-eslint/template-parser": "^19.8.1",
    "@angular/build": "^21.2.12",
    "@angular/cli": "^21.2.12",
    "@angular/compiler-cli": "^21.2.14",
    "@angular/language-service": "^21.2.14",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.0",
    "@ionic/angular-toolkit": "^12.1.1",
    "@ngrx/eslint-plugin": "^21.1.0",
    "@ngrx/schematics": "^21.1.0",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.9.0",
    "@typescript-eslint/parser": "^8.9.0",
    "eslint": "^9.12.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsdoc": "^50.4.1",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "eslint-plugin-prettier": "^5.2.1",
    "googleapis": "^150.0.1",
    "husky": "^9.1.7",
    "jasmine-core": "~5.1.0",
    "jasmine-spec-reporter": "^7.0.0",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "lint-staged": "^15.2.2",
    "patch-package": "^8.0.1",
    "prettier": "3.3.3",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.0"
  },
  "overrides": {
    "superagent": "npm:superagent@latest"
  },
  "description": "An open-source collaboration platform for worker-owned cooperatives, nonprofits, and private organizations, built with Ionic and Firebase, to foster growth, real-time data-driven decision-making, and address basic human needs through community-based solutions.",
  "prettier": {
    "semi": true,
    "trailingComma": "all",
    "singleQuote": false,
    "bracketSpacing": false,
    "printWidth": 80,
    "tabWidth": 2
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,scss,md}": [
      "prettier --write",
      "git add"
    ]
  }
}
