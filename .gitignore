# Specifies intentionally untracked files to ignore when using Git
# Documentation: http://git-scm.com/docs/gitignore

# === General ===
*~
*.sw[mnpcod]
.tmp
*.tmp
*.tmp.*
*.log
log.txt
.history/*
/.sourcemaps
/.versions
/coverage
/connect.lock
/coverage
/libpeerconnection.log
testem.log
/typings
.DS_Store
Thumbs.db
$RECYCLE.BIN/

# === Environment Variables ===
# .env.development IS tracked — it holds the public dev Firebase config so
# new contributors can `npm install && npm start` out of the box. Do not put
# secrets here.
.env.production
# Generated by generate-env.js from .env.* — never commit (would leak
# production Firebase config + Google Maps API key on prod runs).
# src/environments/environment.example.ts is the tracked shape reference.
src/environments/environment.ts
src/environments/environment.prod.ts

# === Generated from *.template by generate-env.js ===
src/index.html
src/funding.json

# === Compiled Output ===
/dist
/tmp
/out-tsc
/bazel-out

# === Node ===
/node_modules
npm-debug.log
yarn-error.log
# package-lock.json // need this file for faster ci/cd with GitHub Actions

# === IDEs and Editors ===
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-project
*.sublime-workspace

# === Visual Studio Code ===
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
UserInterfaceState.xcuserstate

# === Angular ===
/.angular
/.angular/cache
.sass-cache/

# === Ionic ===
/.ionic
/www
/platforms
/plugins
/public
/android/
/ios/

# === Firebase ===
.firebase
.firebase/
firebase-debug.log
firestore-debug.log
ui-debug.log

# === Salesforce ===
.sfdx

# === Other ===
/prod/
# Android signing — never commit
android/keystore.properties
prod/ascend-release.keystore
